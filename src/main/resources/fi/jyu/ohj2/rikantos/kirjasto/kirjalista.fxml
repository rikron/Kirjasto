<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="500.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.rikantos.kirjasto.controller.KirjalistaController">
   <children>
      <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="NEVER">
         <children>
            <Label text="Nimi" />
            <TextField fx:id="nimiTxt" prefWidth="20.0" VBox.vgrow="ALWAYS" />
            <Label text="Tekijä" />
            <TextField fx:id="tekijaTxt" VBox.vgrow="NEVER" />
            <Label text="ISBN" />
            <TextField fx:id="isbnTxt" VBox.vgrow="NEVER" />
            <HBox alignment="TOP_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="muokkaaKirjaa" mnemonicParsing="false" text="Muokkaa" />
                  <Button fx:id="lisaaKirja" mnemonicParsing="false" text="Lisää" />
                  <Button fx:id="poistaKirja" mnemonicParsing="false" onMouseClicked="#handlePoistaKirja" text="Poista" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS">
         <children>
            <Label alignment="CENTER" text="Kirjat" />
            <TableView fx:id="kirjaTaulu" VBox.vgrow="ALWAYS" />
            <HBox alignment="TOP_CENTER" prefHeight="50.0" VBox.vgrow="NEVER" />
         </children>
      </VBox>
   </children>
</HBox>
