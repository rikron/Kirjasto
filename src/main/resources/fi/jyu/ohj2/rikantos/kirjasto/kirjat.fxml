<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.rikantos.kirjasto.controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Lainattavissa" />
   <TableView fx:id="lainattavissaTable" prefHeight="200.0" VBox.vgrow="ALWAYS" />
   <Label text="Lainaamasi" />
   <TableView fx:id="lainaamatTable" prefHeight="200.0" VBox.vgrow="ALWAYS" />
   <HBox alignment="TOP_RIGHT" spacing="10.0">
      <children>
         <TextField fx:id="lainaajanNimiTxt" maxWidth="200.0" promptText="Syötä nimesi..." />
         <Button fx:id="siirryKirjaListaanBtn" mnemonicParsing="false" onMouseClicked="#handleSiirryKirjalistaan" text="Siirry kirjalistaan" />
          <Button fx:id="lainaaKirjaBtn" onMouseClicked="#handleLainaaKirja" text="Lainaa" />
         <Button fx:id="palautaKirjaBtn" mnemonicParsing="false" onMouseClicked="#handlePalautaKirja" text="Palauta" />
      </children>
   </HBox>
</VBox>
