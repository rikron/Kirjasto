<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.rikantos.kirjasto.controller.MainController">
   <children>
      <Label alignment="TOP_LEFT" text="Kirjat" />
      <TableView fx:id="kirjaLista" prefHeight="300.0" prefWidth="200.0">
        <columns>
          <TableColumn prefWidth="75.0" text="C1" />
          <TableColumn prefWidth="75.0" text="C2" />
        </columns>
      </TableView>
      <HBox alignment="TOP_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="siirryLainaamaan" mnemonicParsing="false" onMouseClicked="#handleSiirryLainauksiin" text="Siirry lainauksiin" />
            <Button fx:id="lisaaKirja" mnemonicParsing="false" onMouseClicked="#handleLisaaKirja" text="Lisää" />
            <Button fx:id="poistaKirja" mnemonicParsing="false" onMouseClicked="#handlePoistaKirja" text="Poista" />
         </children>
      </HBox>
   </children>
</VBox>
